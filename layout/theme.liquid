<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the base font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% unless settings.type_heading_font.system? %}
      {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the base CSS %}
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}

    {% render 'meta-tags' %}

    <script>
      window.theme = {
        settings: {
          cart_auto_open: {{ settings.cart_auto_open | json }}
        },
        routes: {
          cart_add_url: '{{ routes.cart_add_url }}',
          cart_url: '{{ routes.cart_url }}',
          cart_update_url: '{{ routes.cart_update_url }}',
          cart_change_url: '{{ routes.cart_change_url }}',
          cart_clear_url: '{{ routes.cart_clear_url }}'
        },
        strings: {
          addToCart: {{ 'products.product.add_to_cart' | t | json }},
          soldOut: {{ 'products.product.sold_out' | t | json }},
          unavailable: {{ 'products.product.unavailable' | t | json }}
        }
      };
    </script>

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    {{ content_for_header }}
  </head>

  <body>
    <a class="skip-link visually-hidden-focusable" href="#main-content">{{ 'accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {{ 'component-product-card.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'component-product-form.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'component-quick-add.js' | asset_url }}" defer="defer"></script>

    <quick-add-modal>
      {%- render 'quick-add-modal' -%}
    </quick-add-modal>
  </body>
</html>
