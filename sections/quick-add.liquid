{%- comment -%}
  File: sections/quick-add.liquid
  Description: AJAX content loaded into #QuickAddModal via fetch.
  Design: Left  = full-bleed image, grab-to-drag on desktop,
                  swipe on mobile, prev/next arrows bottom-left.
          Right = vendor · title (linked) · price · variant-picker
                  · buy-buttons block structure (mirrors buy-buttons.liquid)
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'ProductForm-' | append: section.id
-%}

<div class="qa">
  <div class="qa__layout">
    {%- comment -%} ── LEFT: full-bleed image slider ── {%- endcomment -%}
    <div class="qa__media">
      {%- if product.media.size > 0 -%}
        <div
          class="qa__slides"
          id="qa-slides-{{ section.id }}"
          data-total="{{ product.media.size }}"
        >
          {%- for media in product.media -%}
            <div
              class="qa__slide{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
            >
              {%- if media.media_type == 'image' -%}
                <img
                  src="{{ media | image_url: width: 1000 }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  width="{{ media.width }}"
                  height="{{ media.height }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  decoding="async"
                  draggable="false"
                >
              {%- else -%}
                {{ media | media_tag: image_size: '900x', autoplay: false, loop: true, controls: true }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="qa__arrows">
            <button
              class="qa__arrow-btn"
              type="button"
              data-slides-id="qa-slides-{{ section.id }}"
              data-dir="-1"
              aria-label="{{ 'general.pagination.previous' | t }}"
            >
              {%- render 'icon', name: 'arrow-left' -%}
            </button>
            <button
              class="qa__arrow-btn"
              type="button"
              data-slides-id="qa-slides-{{ section.id }}"
              data-dir="1"
              aria-label="{{ 'general.pagination.next' | t }}"
            >
              {%- render 'icon', name: 'arrow-right' -%}
            </button>
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="qa__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── RIGHT: product info ── {%- endcomment -%}
    <div class="qa__content">
      <div class="qa__inner">
        {%- if product.vendor != blank -%}
          <p class="qa__vendor">{{ product.vendor | upcase }}</p>
        {%- endif -%}

        <h2 class="qa__title" id="QuickAddTitle">
          <a href="{{ product.url }}" class="qa__title-link" data-quick-add-close>
            {{- product.title -}}
          </a>
        </h2>

        <div class="qa__price-row" id="qa-price-{{ section.id }}">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="qa__price qa__price--sale">{{ current_variant.price | money }}</span>
            <s class="qa__compare">{{ current_variant.compare_at_price | money }}</s>
          {%- else -%}
            <span class="qa__price">{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>

        {%- unless product.has_only_default_variant -%}
          <div class="qa__variant-picker">
            {%- render 'product-variant-picker',
              product: product,
              section: section,
              form_id: product_form_id,
              picker_style: 'buttons',
              show_swatches: true,
              show_availability: true
            -%}
          </div>
        {%- endunless -%}

        {%- comment -%}
          Buy block — mirrors buy-buttons.liquid HTML/class structure exactly
          so its {% stylesheet %} rules govern layout automatically.
          Cannot use {% render %} because buy-buttons.liquid uses
          {% content_for 'blocks' %} which only resolves in block context.
        {%- endcomment -%}
        <div
          class="product-form-block qa__buy-block"
          style="--buy-pt:0px;--buy-pb:0px;--buy-pl:0px;--buy-pr:0px;"
        >
          <product-form class="product-form">
            {%- form 'product',
              product,
              id: product_form_id,
              class: 'form',
              novalidate: 'novalidate',
              data-type: 'add-to-cart-form'
            -%}
              <input
                type="hidden"
                name="id"
                value="{{ current_variant.id }}"
                disabled
                data-qa-variant-id
              >

              <div
                class="product-form__error-message-wrapper"
                role="alert"
                aria-live="assertive"
                aria-atomic="true"
                hidden
              >
                <span class="visually-hidden">{{ 'general.error' | t }}</span>
                <span class="product-form__error-message"></span>
              </div>

              {%- comment -%} .product-form__buttons mirrors buy-buttons.liquid exactly {%- endcomment -%}
              <div class="product-form__buttons">
                {%- comment -%} Quantity — .product-form__quantity matches buy-buttons.liquid {%- endcomment -%}
                <div class="product-form__quantity qa__qty">
                  {%- render 'quantity-input',
                    id: section.id,
                    name: 'quantity',
                    value: 1,
                    min: 1,
                    form_id: product_form_id
                  -%}
                </div>

                {%- comment -%} ATC — .product-form__add-to-cart matches buy-buttons.liquid {%- endcomment -%}
                <div class="product-form__add-to-cart qa__atc">
                  <button
                    type="submit"
                    name="add"
                    class="qa__atc-btn"
                    form="{{ product_form_id }}"
                    {%- unless current_variant.available %}
                      disabled
                    {%- endunless %}
                  >
                    <span class="qa__atc-label">
                      {%- if current_variant.available -%}
                        {{ 'products.product.add_to_cart' | t | upcase }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t | upcase }}
                      {%- endif -%}
                    </span>
                    <span class="qa__atc-spinner" aria-hidden="true"></span>
                  </button>
                </div>

                {%- comment -%} BUY IT NOW — .product-form__dynamic-checkout matches buy-buttons.liquid {%- endcomment -%}
                {%- if product.available -%}
                  <div class="product-form__dynamic-checkout qa__buy-now">
                    {{ form | payment_button }}
                  </div>
                {%- endif -%}
              </div>
            {%- endform -%}
          </product-form>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" data-product-json>
  {{ product | json }}
</script>
