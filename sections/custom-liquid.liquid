{%- style -%}
  .custom-liquid-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="custom-liquid-{{ section.id }} page-width color-{{ section.settings.color_scheme.id | default: 'scheme-1' }}">
  {{ section.settings.custom_liquid }}
</div>

{% schema %}
{
  "name": "t:general.custom_liquid",
  "tag": "section",
  "class": "custom-liquid page-width",
  "settings": [
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:general.custom_liquid",
      "info": "t:general.custom_liquid_info"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:general.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:general.padding_bottom",
      "default": 36
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:general.custom_liquid"
    }
  ]
}
{% endschema %}
