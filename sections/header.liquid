<header>
  {%- comment -%} Logo / shop name {%- endcomment -%}
  <a href="{{ routes.root_url }}" class="header__logo-link">
    {%- if settings.logo != blank -%}
      {{
        settings.logo
        | image_url: width: settings.logo_width
        | image_tag:
          class: 'header__logo-img',
          alt: settings.logo_alt | default: shop.name,
          width: settings.logo_width,
          loading: 'eager',
          fetchpriority: 'high'
      }}
    {%- else -%}
      <span class="header__logo-text">{{ shop.name }}</span>
    {%- endif -%} 
  </a>

  <nav class="header__menu" aria-label="Main navigation">
    {%- for link in section.settings.menu.links -%}
      {{ link.title | link_to: link.url }}
    {%- endfor -%}
  </nav>

  <div class="header__icons">
    {%- if shop.customer_accounts_enabled -%}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {%- endif -%}

    <a href="{{ routes.cart_url }}" aria-label="Cart ({{ cart.item_count }} items)">
      {%- if cart.item_count > 0 -%}
        <sup>{{ cart.item_count }}</sup>
      {%- endif -%}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  header {
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .header__logo-link {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    flex-shrink: 0;
  }

  .header__logo-img {
    width: var(--logo-width);
    max-width: var(--logo-width);
    height: auto;
    display: block;
  }

  .header__logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
  }

  header nav.header__menu {
    display: flex;
    gap: 1rem;
  }

  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }

  header svg {
    width: 2rem;
  }

  header .header__icons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
