{% comment %}
  Section: main-search
  Path: sections/main-search.liquid
  Description: Renders the search results for products, articles, and pages.
  Blocks: None
  Settings: None
{% endcomment %}

{%- render 'color-scheme', scheme: section.settings.color_scheme, selector: '#shopify-section-' | append: section.id -%}

<section class="section-main-search">
  <div class="page-width">
    <h1>{{ 'search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="hidden" name="type" value="product,article,page">
      <label for="SearchInput" class="visually-hidden">{{ 'search.placeholder' | t }}</label>
      <input
        id="SearchInput"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        autocomplete="off"
        class="search-form__input"
        data-search-input
      >
      <button type="submit" class="button button--primary search-form__submit">
        {{- 'search.submit' | t -}}
      </button>
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {% else %}
        <p>{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        <div class="search-results" aria-live="polite">
          {% paginate search.results by 24 %}
            {% for item in search.results %}
              <div class="search-result-item">
                {% if item.object_type == 'product' %}
                  {% render 'product-card', product: item %}
                {% else %}
                  <div class="search-result-item__generic">
                    {% assign featured_image = item.featured_image | default: item.image %}
                    {% if featured_image %}
                      {% render 'image', class: 'search-result-item__image', image: featured_image, url: item.url, width: 400 %}
                    {% endif %}
                    <h3 class="search-result-item__title">
                      <a href="{{ item.url }}">{{ item.title | escape }}</a>
                    </h3>
                    <p class="search-result-item__excerpt">
                      {{- item.content | strip_html | truncatewords: 30 -}}
                    </p>
                  </div>
                {% endif %}
              </div>
            {% endfor %}

            {% if paginate.pages > 1 %}
              {% render 'pagination', paginate: paginate %}
            {% endif %}
          {% endpaginate %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .section-main-search {
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
  }

  .search-form {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-10);
    max-width: var(--content-narrow);
    margin-left: auto;
    margin-right: auto;
  }

  .search-form__input {
    flex: 1;
    padding: var(--space-3) var(--space-4);
    border: 1px solid oklch(from var(--color-text) l c h / 0.12);
    border-radius: var(--radius-sm);
    background: var(--color-background);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--font-size-md);
  }

  .search-form__input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .search-form__submit {
    flex-shrink: 0;
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: var(--space-6);
  }

  @media screen and (min-width: 750px) {
    .search-results {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .search-results {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .search-result-item__generic {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .search-result-item__title {
    margin: 0;
    font-size: var(--font-size-md);
  }

  .search-result-item__title a {
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .search-result-item__title a:hover {
    opacity: 0.7;
  }

  .search-result-item__excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:general.search"
    }
  ]
}
{% endschema %}
