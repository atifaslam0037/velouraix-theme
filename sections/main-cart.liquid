{%- comment -%}
  Section: main-cart.liquid
  Path: sections/main-cart.liquid
  Description: Full cart page. Desktop: table layout (PRODUCT · QUANTITY · TOTAL) + sticky summary.
    Mobile: stacked card layout. All AJAX mutations handled by cart-items-component.
    Settings from global theme settings control optional features (notes, free shipping).
{%- endcomment -%}

{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-quantity-input.css' | asset_url | stylesheet_tag }}
{{ 'section-main-cart.css' | asset_url | stylesheet_tag }}

<script src="{{ 'component-quantity-input.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'component-cart-items.js'     | asset_url }}" defer="defer"></script>

{%- comment -%}
  Line-item AJAX lives in cart-items-component inside the products block only. One layout tree so static block ids
  (cart-page-title, cart-page-items) are not duplicated.
{%- endcomment -%}
<div class="main-cart" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <style>
    .cart-page__summary {
      --button-radius: {{ section.settings.corner_radius }}px;
      --cart-summary-radius: {{ section.settings.corner_radius }}px;
    }
    {%- unless section.settings.allow_note -%}
      cart-note, .cart-summary__accordion--note { display: none; }
    {%- endunless -%}
    {%- unless section.settings.allow_discounts -%}
      .cart-summary__accordion--discount { display: none; }
    {%- endunless -%}
    {%- unless section.settings.cart_total -%}
      .cart-summary__row--total { display: none; }
    {%- endunless -%}
    {%- unless section.settings.installments -%}
      .cart-summary__tax-note { display: none; }
    {%- endunless -%}
  </style>
  <div class="cart-page page-width{% if cart.empty? %} cart-page--empty{% endif %}">
    <div class="cart-page__title">
      {%- content_for 'block', id: 'cart-page-title', type: '_cart-title' %}
    </div>

    {%- unless cart.empty? -%}
      <div class="cart-page__table-header" aria-hidden="true">
        <span class="cart-page__col-label">{{- 'cart.column_product' | t | upcase -}}</span>
        <span class="cart-page__col-label cart-page__col-label--qty">{{- 'cart.column_quantity' | t | upcase -}}</span>
        <span class="cart-page__col-label cart-page__col-label--total">{{- 'cart.column_total' | t | upcase -}}</span>
      </div>
    {%- endunless -%}

    <div class="cart-page__items">
      {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' %}
    </div>

    {%- unless cart.empty? -%}
      <div class="cart-page__summary">
        {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
      </div>
    {%- endunless -%}

    {%- content_for 'blocks' -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_cart.name",
  "tag": "section",
  "class": "section-main-cart",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "page", "label": "Page" },
        { "value": "full", "label": "Full" }
      ],
      "default": "page"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top",
      "default": 58
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom",
      "default": 54
    },
    {
      "type": "header",
      "content": "Theme Settings"
    },
    {
      "type": "select",
      "id": "product_title_case",
      "label": "Product title case",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "uppercase", "label": "Uppercase" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Border style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Corner radius",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "cart_items",
      "label": "Cart items",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "allow_note",
      "label": "Allow note to seller",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "allow_discounts",
      "label": "Allow discounts in cart",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "cart_total",
      "label": "Cart total",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "installments",
      "label": "Installments",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.main_cart.presets.name"
    }
  ]
}
{% endschema %}
