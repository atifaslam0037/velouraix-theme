{% comment %}
  Main cart page section.
  Follows the reference theme's section-rendering pattern:
    - cart-items-component is the root element for AJAX re-rendering
    - <template id="empty-cart-template"> enables seamless empty-state transition
    - Content is split into private theme blocks (_cart-title, _cart-products, _cart-summary)
{% endcomment %}

{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-quantity-input.css' | asset_url | stylesheet_tag }}

<script src="{{ 'component-quantity-input.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'component-cart-items.js' | asset_url }}" defer="defer"></script>

<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  {%- comment -%}
    Empty-state template: cloned and injected by JS when cart transitions to empty.
    force_empty: true ensures the block renders even when the cart technically has items
    (needed so the template has a valid DOM structure to clone).
  {%- endcomment -%}
  <template id="empty-cart-template">
    <div class="cart-page cart-page--empty page-width">
      <div class="cart-page__title">
        {%- content_for 'block', id: 'cart-page-title', type: '_cart-title', force_empty: true %}
      </div>
      <div class="cart-page__items">
        {%- content_for 'block', id: 'cart-page-items', type: '_cart-products', force_empty: true %}
      </div>
    </div>
  </template>

  {% # theme-check-disable UniqueStaticBlockId %}
  <div class="cart-page page-width{% if cart.empty? %} cart-page--empty{% endif %}">
    <div class="cart-page__title">
      {%- content_for 'block', id: 'cart-page-title', type: '_cart-title' %}
    </div>

    <div class="cart-page__items">
      {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' %}
    </div>

    {%- unless cart.empty? -%}
      <div class="cart-page__summary">
        {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
      </div>
    {%- endunless -%}
  </div>
  {% # theme-check-enable UniqueStaticBlockId %}

</cart-items-component>

{% stylesheet %}
  .cart-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .cart-page__title {
    grid-column: 1 / -1;
  }

  .cart-page--empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }

  .cart-page--empty .cart-page__title {
    margin-top: var(--space-8);
  }

  @media screen and (min-width: 990px) {
    .cart-page {
      grid-template-columns: 1fr min(380px, 40%);
      grid-template-rows: auto 1fr;
      gap: 0 var(--space-12);
      align-items: flex-start;
    }

    .cart-page__title {
      grid-column: 1 / -1;
      padding-bottom: var(--space-6);
    }

    .cart-page__items {
      grid-row: 2;
      grid-column: 1;
    }

    .cart-page__summary {
      grid-row: 2;
      grid-column: 2;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "tag": "div",
  "class": "cart-section",
  "settings": []
}
{% endschema %}
