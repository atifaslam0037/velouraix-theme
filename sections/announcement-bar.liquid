{%- if section.settings.show_announcement and section.blocks.size > 0 -%}
  <div
    class="announcement-bar color-{{ section.settings.color_scheme.id | default: 'scheme-1' }}"
    role="region"
    aria-label="Announcement"
    style="
      --ann-bg: {{ section.settings.color_scheme.settings.background | default: '#FFFFFF' }};
      --ann-color: {{ section.settings.color_scheme.settings.text | default: '#121212' }};
    "
  >
    <div class="announcement-bar__inner">
      <announcement-slider
        class="announcement-slider"
        data-autoplay="{%- if section.blocks.size > 1 -%}true{%- else -%}false{%- endif -%}"
        data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
      >
        {%- for block in section.blocks -%}
          <div
            class="announcement-slider__slide {% if forloop.first %}is-active{% endif %}"
            {{ block.shopify_attributes }}
            data-index="{{ forloop.index0 }}"
            style="
              --block-font: {% if block.settings.font == 'heading' %}var(--font-heading){% else %}var(--font-body){% endif %};
              --block-size: {{ block.settings.size }}px;
              --block-weight: {% if block.settings.weight == 'default' %}inherit{% else %}{{ block.settings.weight }}{% endif %};
              --block-spacing: {% case block.settings.letter_spacing %}{% when 'tight' %}-0.02em{% when 'loose' %}0.1em{% else %}normal{% endcase %};
              --block-case: {% if block.settings.text_case == 'uppercase' %}uppercase{% else %}none{% endif %};
            "
          >
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__link rte">
                {{- block.settings.text -}}
              </a>
            {%- else -%}
              <div class="announcement-bar__text rte">
                {{- block.settings.text -}}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </announcement-slider>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background-color: var(--ann-bg);
    color: var(--ann-color);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    z-index: 10;
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-2, 0.5rem);
    min-height: 40px;
    width: 100%;
  }

  .announcement-slider {
    display: block;
    width: 100%;
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  .announcement-slider__slide {
    font-family: var(--block-font, var(--font-primary, sans-serif));
    font-size: var(--block-size, var(--font-size-xs, 0.75rem));
    font-weight: var(--block-weight, 500);
    letter-spacing: var(--block-spacing, 0.08em);
    text-transform: var(--block-case, uppercase);
    width: 100%;
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  /* Reset paragraph styling within richtext so it honors the slider slide styles */
  .announcement-slider__slide .rte p {
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    margin: 0;
    line-height: 1.5;
  }

  .announcement-slider__slide.is-active {
    position: relative;
    top: auto;
    transform: none;
    opacity: 1;
    visibility: visible;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .announcement-bar__link,
  .announcement-bar__text {
    color: inherit;
    text-decoration: none;
    display: inline-block;
    padding: 0 var(--space-4, 1rem);
  }

  .announcement-bar__link:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .announcement-slider__slide {
      font-size: calc(var(--block-size, var(--font-size-xs, 0.75rem)) * 0.9);
    }
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('announcement-slider')) {
    class AnnouncementSlider extends HTMLElement {
      constructor() {
        super();
        this.autoplay = this.dataset.autoplay === 'true';
        this.speed = parseInt(this.dataset.speed) || 5000;
        this.slides = this.querySelectorAll('.announcement-slider__slide');
        this.currentIndex = 0;
        this.interval = null;

        if (this.slides.length > 1 && this.autoplay) {
          this.initSlider();
        }
      }

      initSlider() {
        this.interval = setInterval(this.nextSlide.bind(this), this.speed);

        this.addEventListener('mouseenter', () => clearInterval(this.interval));
        this.addEventListener('mouseleave', () => {
          this.interval = setInterval(this.nextSlide.bind(this), this.speed);
        });
      }

      nextSlide() {
        this.slides[this.currentIndex].classList.remove('is-active');
        this.currentIndex = (this.currentIndex + 1) % this.slides.length;
        this.slides[this.currentIndex].classList.add('is-active');
      }
    }

    customElements.define('announcement-slider', AnnouncementSlider);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "announcement-bar page-width",
  "max_blocks": 5,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "t:general.show_announcement",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:general.autoplay_speed",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "t:general.text",
          "default": "<p>Welcome to our store</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:general.link"
        },
        {
          "type": "header",
          "content": "t:general.typography"
        },
        {
          "type": "select",
          "id": "font",
          "label": "t:general.font",
          "options": [
            {
              "value": "body",
              "label": "t:general.body"
            },
            {
              "value": "subheading",
              "label": "t:general.subheading"
            },
            {
              "value": "heading",
              "label": "t:general.heading"
            }
          ],
          "default": "subheading"
        },
        {
          "type": "select",
          "id": "size",
          "label": "t:general.size",
          "options": [
            { "value": "10", "label": "t:general.font_size_10" },
            { "value": "11", "label": "t:general.font_size_11" },
            { "value": "12", "label": "t:general.font_size_12" },
            { "value": "13", "label": "t:general.font_size_13" },
            { "value": "14", "label": "t:general.font_size_14" },
            { "value": "15", "label": "t:general.font_size_15" },
            { "value": "16", "label": "t:general.font_size_16" }
          ],
          "default": "12"
        },
        {
          "type": "select",
          "id": "weight",
          "label": "t:general.weight",
          "options": [
            { "value": "default", "label": "t:general.default" },
            { "value": "400", "label": "t:general.normal" },
            { "value": "500", "label": "t:general.medium" },
            { "value": "600", "label": "t:general.semibold" },
            { "value": "700", "label": "t:general.bold" }
          ],
          "default": "default"
        },
        {
          "type": "select",
          "id": "letter_spacing",
          "label": "t:general.letter_spacing",
          "options": [
            { "value": "tight", "label": "t:general.tight" },
            { "value": "normal", "label": "t:general.normal" },
            { "value": "loose", "label": "t:general.loose" }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "text_case",
          "label": "t:general.case",
          "options": [
            { "value": "default", "label": "t:general.default" },
            { "value": "uppercase", "label": "t:general.uppercase" }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
