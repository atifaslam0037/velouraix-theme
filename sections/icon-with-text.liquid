      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Column dividers"
    },
    {
      "type": "checkbox",
      "id": "show_column_dividers",
      "label": "Show column dividers",
      "default": false
    },
    {
