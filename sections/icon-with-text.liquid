      "options": [
        { "value": "none", "label": "None" },
        { "value": "image", "label": "Image" }
      ],
      "default": "none"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.bg_media_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "border",
      "label": "Borders",
