{%- comment -%}
  Block: button
  Path: blocks/button.liquid
  Description: Reusable button block with style, size, and target controls.
  Used in sections that support @theme blocks.
{%- endcomment -%}

{%- liquid
  assign button_label = block.settings.label | escape
-%}

<div class="block-button" {{ block.shopify_attributes }}>
  {%- if block.settings.url != blank and button_label != blank -%}
    <a
      class="block-button__link block-button__link--{{ block.settings.style }} block-button__link--{{ block.settings.size }}"
      href="{{ block.settings.url }}"
      {% if block.settings.new_tab %}
        target="_blank" rel="noopener noreferrer"
      {% endif %}
    >
      {{- button_label -}}
    </a>
  {%- endif -%}
</div>

{% stylesheet %}
.block-button {
  display: block;
}

.block-button__link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: var(--space-11);
  padding: var(--space-3) var(--space-6);
  border: 1px solid transparent;
  border-radius: var(--button-radius);
  font-size: var(--font-size-sm);
  line-height: 1;
  text-decoration: none;
  transition: opacity var(--transition-base);
}

.block-button__link--primary {
  background: var(--color-button);
  color: var(--color-button-text);
}

.block-button__link--secondary {
  border-color: oklch(from var(--color-text) l c h / 0.2);
  color: var(--color-text);
  background: transparent;
}

.block-button__link--ghost {
  border-color: transparent;
  color: var(--color-text);
  background: transparent;
}

.block-button__link--sm { min-height: var(--space-10); }
.block-button__link--md { min-height: var(--space-11); }
.block-button__link--lg { min-height: var(--space-12); }
{% endstylesheet %}

{% schema %}
{
  "name": "Button",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:blocks.button.settings.label.label",
      "default": "t:blocks.button.settings.label.default"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:blocks.button.settings.url.label"
    },
    {
      "type": "select",
      "id": "style",
      "label": "t:blocks.button.settings.style.label",
      "options": [
        { "value": "primary", "label": "t:blocks.button.settings.style.options.primary" },
        { "value": "secondary", "label": "t:blocks.button.settings.style.options.secondary" },
        { "value": "ghost", "label": "t:blocks.button.settings.style.options.ghost" }
      ],
      "default": "primary"
    },
    {
      "type": "select",
      "id": "size",
      "label": "t:blocks.button.settings.size.label",
      "options": [
        { "value": "sm", "label": "t:blocks.button.settings.size.options.sm" },
        { "value": "md", "label": "t:blocks.button.settings.size.options.md" },
        { "value": "lg", "label": "t:blocks.button.settings.size.options.lg" }
      ],
      "default": "md"
    },
    {
      "type": "checkbox",
      "id": "new_tab",
      "label": "t:blocks.button.settings.new_tab.label",
      "default": false
    }
  ],
  "presets": [{ "name": "t:blocks.button.presets.name" }]
}
{% endschema %}
