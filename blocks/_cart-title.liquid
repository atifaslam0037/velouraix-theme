{%- comment -%}
  Block: _cart-title.liquid
  Path: blocks/_cart-title.liquid
  Description: Private theme block. Renders the cart page heading and live item count pill.
    Statically rendered by sections/main-cart.liquid via content_for 'block'.
    The #cart-page-count span is read by CartItemsComponent._syncGlobalUI()
    to update all count displays without a page reload.

  @example
    Rendered from sections/main-cart.liquid via content_for (cart-page-title).
{%- endcomment -%}

{%- liquid
  assign heading_text = block.settings.title
  if heading_text == blank
    assign heading_text = 'cart.title' | t
  endif
  assign cart_qty_total = 0
  for item in cart.items
    assign cart_qty_total = cart_qty_total | plus: item.quantity
  endfor
-%}

<header
  class="cart-title cart-title--{{ block.settings.alignment }} cart-title--{{ block.settings.typography }}"
  role="banner"
  {{ block.shopify_attributes }}
  style="
    --cart-title-padding-top: {{ block.settings.padding_top }}px;
    --cart-title-padding-bottom: {{ block.settings.padding_bottom }}px;
    --cart-title-padding-left: {{ block.settings.padding_left }}px;
    --cart-title-padding-right: {{ block.settings.padding_right }}px;
  "
>
  <h1 class="cart-title__heading" id="cart-page-heading">
    {{- heading_text -}}
  </h1>

  {%- if block.settings.show_count and cart.empty? == false -%}
    <span
      class="cart-title__pill"
      id="cart-page-count"
      aria-live="polite"
      aria-atomic="true"
      aria-label="{{ 'cart.title' | t }}: {{ cart_qty_total }} {{ 'cart.items_count' | t: count: cart_qty_total }}"
    >
      {{- cart_qty_total -}}
    </span>
  {%- endif -%}
</header>

{% stylesheet %}
  /* ── Cart page title block ── */
  .cart-title {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--cart-title-padding-top);
    padding-right: var(--cart-title-padding-right);
    padding-bottom: var(--cart-title-padding-bottom);
    padding-left: var(--cart-title-padding-left);
    border-bottom: 1px solid oklch(from var(--color-text) l c h / 0.1);
  }

  .cart-title__heading {
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
  }

  .cart-title--heading-2 .cart-title__heading {
    font-size: var(--font-h2-size);
  }
  .cart-title--heading-3 .cart-title__heading {
    font-size: var(--font-h3-size);
  }
  .cart-title--heading-4 .cart-title__heading {
    font-size: var(--font-h4-size);
  }

  .cart-title--left .cart-title__heading {
    text-align: left;
  }
  .cart-title--center .cart-title__heading {
    text-align: center;
    width: 100%;
  }
  .cart-title--right .cart-title__heading {
    text-align: right;
    width: 100%;
  }

  .cart-title__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--space-5);
    height: var(--space-5);
    padding-inline: var(--space-2);
    background: oklch(from var(--color-text) l c h / 0.08);
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    font-weight: 400;
    letter-spacing: 0;
    color: var(--color-text);
    line-height: 1;
    border-radius: var(--radius-full);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.cart_title.name",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:blocks.cart_title.settings.title.label",
      "default": "t:blocks.cart_title.settings.title.default"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "t:blocks.cart_title.settings.show_count.label",
      "default": true
    },
    {
      "type": "select",
      "id": "typography",
      "label": "t:blocks.cart_title.settings.typography.label",
      "options": [
        { "value": "heading-2", "label": "t:blocks.cart_title.settings.typography.options.heading_2" },
        { "value": "heading-3", "label": "t:blocks.cart_title.settings.typography.options.heading_3" },
        { "value": "heading-4", "label": "t:blocks.cart_title.settings.typography.options.heading_4" }
      ],
      "default": "heading-3"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:blocks.cart_title.settings.alignment.label",
      "options": [
        { "value": "left", "label": "t:blocks.cart_title.settings.alignment.options.left" },
        { "value": "center", "label": "t:blocks.cart_title.settings.alignment.options.center" },
        { "value": "right", "label": "t:blocks.cart_title.settings.alignment.options.right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:blocks.cart_title.settings.padding_header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:blocks.cart_title.settings.padding_top.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:blocks.cart_title.settings.padding_bottom.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:blocks.cart_title.settings.padding_left.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:blocks.cart_title.settings.padding_right.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
