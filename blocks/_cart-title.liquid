{%- comment -%}
  Block: _cart-title.liquid
  Path: blocks/_cart-title.liquid
  Description: Private theme block. Renders the cart page heading and live item count pill.
    Statically rendered by sections/main-cart.liquid via content_for 'block'.
    The #cart-page-count span is read by CartItemsComponent._syncGlobalUI()
    to update all count displays without a page reload.

  @example
  {%- content_for 'block', id: 'cart-page-title', type: '_cart-title' %}
{%- endcomment -%}

<header class="cart-title" role="banner">
  <h1 class="cart-title__heading" id="cart-page-heading">
    {{- 'cart.title' | t -}}
  </h1>

  {%- unless cart.empty? -%}
    <span
      class="cart-title__pill"
      id="cart-page-count"
      aria-live="polite"
      aria-atomic="true"
      aria-label="{{ 'cart.title' | t }}: {{ cart.item_count }} {{ 'cart.items_count' | t: count: cart.item_count }}"
    >
      {{- cart.item_count -}}
    </span>
  {%- endunless -%}
</header>

{% stylesheet %}
/* ── Cart page title block ── */
.cart-title {
  display: flex;
  align-items: baseline;
  gap: var(--space-4);
  padding-bottom: var(--space-5);
  border-bottom: 1px solid oklch(from var(--color-text) l c h / 0.1);
}

.cart-title__heading {
  font-family: var(--font-primary);
  font-size: var(--font-size-sm);
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text);
  margin: 0;
}

.cart-title__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: var(--space-5);
  height: var(--space-5);
  padding-inline: var(--space-2);
  background: oklch(from var(--color-text) l c h / 0.08);
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0;
  color: var(--color-text);
  line-height: 1;
  border-radius: var(--radius-full);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Cart title"
}
{% endschema %}
