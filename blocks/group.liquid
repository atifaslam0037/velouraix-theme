{%- comment -%}
  Block: group
  Path: blocks/group.liquid
  Description: Reusable group container block for spacing and alignment.
               Accepts ALL @theme blocks and @app blocks as children.
{%- endcomment -%}

{% stylesheet %}
  .block-group {
    display: flex;
    position: relative;
    overflow: hidden;
  }

  .block-group--vertical {
    flex-direction: column;
  }
  .block-group--horizontal {
    flex-direction: row;
    flex-wrap: wrap;
  }

  .block-group--align-left {
    align-items: flex-start;
  }
  .block-group--align-center {
    align-items: center;
  }
  .block-group--align-right {
    align-items: flex-end;
  }

  .block-group--justify-top {
    justify-content: flex-start;
  }
  .block-group--justify-center {
    justify-content: center;
  }
  .block-group--justify-bottom {
    justify-content: flex-end;
  }
  .block-group--justify-space-between {
    justify-content: space-between;
  }

  .block-group--width-fit {
    width: fit-content;
    flex-shrink: 0;
  }
  .block-group--width-fill {
    width: 100%;
    flex: 1 1 100%;
    min-width: 0;
  }
  .block-group--width-custom {
    min-width: 0;
  }

  .block-group--height-fit {
    height: fit-content;
  }
  .block-group--height-fill {
    height: 100%;
    flex: 1 1 auto;
  }

  .block-group--border-none {
    border: none;
  }
  .block-group--border-solid {
    border: 1px solid var(--block-group-border-color, currentColor);
  }

  .block-group__bg-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  .block-group__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .block-group__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: inherit;
    align-items: inherit;
    justify-content: inherit;
    gap: inherit;
    width: 100%;
    min-width: 0;
  }

  .block-group__link {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: block;
  }

  @media (max-width: 749px) {
    .block-group--mobile-width-fit {
      width: fit-content;
      flex-shrink: 0;
    }
    .block-group--mobile-width-fill {
      width: 100%;
      flex: 1 1 100%;
      min-width: 0;
    }
    .block-group--mobile-width-custom {
      width: var(--block-group-mobile-custom-width, 100%);
      min-width: 0;
    }
  }
{% endstylesheet %}

{%- liquid
  assign has_bg_image = false
  assign has_overlay = false
  assign has_link = false

  if block.settings.bg_media_type == 'image' and block.settings.bg_image != blank
    assign has_bg_image = true
  endif

  if block.settings.overlay_opacity > 0
    assign has_overlay = true
  endif

  if block.settings.block_link != blank
    assign has_link = true
  endif

  assign width_style = ''
  assign height_style = ''

  if block.settings.width == 'custom'
    assign width_style = 'width: ' | append: block.settings.custom_width | append: '%;'
  endif

  if block.settings.height == 'custom'
    assign height_style = 'height: ' | append: block.settings.custom_height | append: 'px;'
  endif

  assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0
-%}

<div
  class="
    block-group
    block-group--{{ block.settings.direction }}
    block-group--align-{{ block.settings.alignment }}
    block-group--justify-{{ block.settings.position }}
    block-group--border-{{ block.settings.border }}
    block-group--width-{{ block.settings.width }}
    block-group--height-{{ block.settings.height }}
    block-group--mobile-width-{{ block.settings.mobile_width }}
    color-{{ block.settings.color_scheme }}
  "
  style="
    gap: {{ block.settings.gap }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    border-radius: {{ block.settings.corner_radius }}px;
    --block-group-border-color: {{ block.settings.border_color }};
    --block-group-mobile-custom-width: {{ block.settings.custom_mobile_width }}%;
    {{ width_style }}
    {{ height_style }}
  "
  {{ block.shopify_attributes }}
>
  {%- if has_bg_image -%}
    {{
      block.settings.bg_image
      | image_url: width: 1920
      | image_tag:
        class: 'block-group__bg-media',
        loading: 'lazy',
        alt: '',
        widths: '375, 750, 1100, 1500, 1920',
        sizes: '100vw'
    }}
  {%- endif -%}

  {%- if has_overlay -%}
    <div
      class="block-group__overlay"
      aria-hidden="true"
      style="background-color: {{ block.settings.overlay_color }}; opacity: {{ overlay_opacity }};"
    ></div>
  {%- endif -%}

  <div class="block-group__inner">
    {% content_for 'blocks' %}
  </div>

  {%- if has_link -%}
    <a
      class="block-group__link"
      href="{{ block.settings.block_link }}"
      {% if block.settings.open_in_new_tab %}
        target="_blank"
        rel="noopener noreferrer"
      {% endif %}
      aria-label="{{ block.settings.block_link }}"
    ></a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:blocks.group.name",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:general.direction",
      "options": [
        { "value": "vertical", "label": "t:general.vertical" },
        { "value": "horizontal", "label": "t:general.horizontal" }
      ],
      "default": "vertical"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:general.alignment",
      "options": [
        { "value": "left", "label": "t:general.left" },
        { "value": "center", "label": "t:general.center" },
        { "value": "right", "label": "t:general.right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:general.position",
      "options": [
        { "value": "top", "label": "t:general.top" },
        { "value": "center", "label": "t:general.center" },
        { "value": "bottom", "label": "t:general.bottom" },
        { "value": "space-between", "label": "t:general.space_between" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:general.gap",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:general.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:general.width",
      "options": [
        { "value": "fit", "label": "t:general.fit" },
        { "value": "fill", "label": "t:general.fill" },
        { "value": "custom", "label": "t:general.custom" }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:general.custom_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%",
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "mobile_width",
      "label": "t:general.mobile_width",
      "options": [
        { "value": "fit", "label": "t:general.fit" },
        { "value": "fill", "label": "t:general.fill" },
        { "value": "custom", "label": "t:general.custom" }
      ],
      "default": "fill"
    },
    {
      "type": "range",
      "id": "custom_mobile_width",
      "label": "t:general.custom_mobile_width",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%",
      "visible_if": "{{ block.settings.mobile_width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "height",
      "label": "t:general.height",
      "options": [
        { "value": "fit", "label": "t:general.fit" },
        { "value": "fill", "label": "t:general.fill" },
        { "value": "custom", "label": "t:general.custom" }
      ],
      "default": "fit"
    },
    {
      "type": "range",
      "id": "custom_height",
      "label": "t:general.custom_height",
      "min": 50,
      "max": 800,
      "step": 10,
      "default": 300,
      "unit": "px",
      "visible_if": "{{ block.settings.height == 'custom' }}"
    },
    {
      "type": "header",
      "content": "t:general.appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:general.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "bg_media_type",
      "label": "t:general.background_media",
      "options": [
        { "value": "none", "label": "t:general.none" },
        { "value": "image", "label": "t:general.image" }
      ],
      "default": "none"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "t:general.background_image"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:general.borders",
      "options": [
        { "value": "none", "label": "t:general.none" },
        { "value": "solid", "label": "t:general.solid" }
      ],
      "default": "none"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:general.border_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "t:general.corner_radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:general.background_overlay_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:general.overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "t:general.block_link"
    },
    {
      "type": "url",
      "id": "block_link",
      "label": "t:general.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:general.open_link_in_new_tab",
      "default": false
    },
    {
      "type": "header",
      "content": "t:general.padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:general.top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:general.bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:general.left",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:general.right",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "t:blocks.group.presets.name" }]
}
{% endschema %}
