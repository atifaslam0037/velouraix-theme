{% doc %}
  @name _cart-products

  @description Private theme block. Renders cart line items on the cart page,
    or the empty-cart state. Statically rendered by sections/main-cart.liquid
    via content_for 'block'. Image size, aspect ratio, dividers, and vendor
    visibility are all merchant-configurable via schema settings.

  @example
  Rendered from sections/main-cart.liquid via content_for (cart-page-items).
{% enddoc %}

<div
  class="cart-products-block"
  {{ block.shopify_attributes }}
  style="
    --cart-products-padding-top: {{ block.settings.padding_top }}px;
    --cart-products-padding-bottom: {{ block.settings.padding_bottom }}px;
    --cart-products-padding-left: {{ block.settings.padding_left }}px;
    --cart-products-padding-right: {{ block.settings.padding_right }}px;
    --cart-products-image-size: {{ block.settings.product_image_size }}px;
  "
>
{%- if cart.empty? -%}
  <div class="cart-empty">
    <p class="cart-empty__message">{{- 'cart.empty' | t -}}</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      class="cart-empty__cta"
    >
      {{- 'cart.continue_shopping' | t -}}
    </a>
  </div>
{%- else -%}
  {%- render 'cart-items',
    context: 'page',
    show_vendor: block.settings.show_vendor,
    show_dividers: block.settings.show_dividers,
    image_size: block.settings.product_image_size,
    aspect_ratio: block.settings.aspect_ratio
  -%}
{%- endif -%}
</div>

{% stylesheet %}
/* ── Cart page empty state ── */
.cart-empty {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-6);
  padding-block: var(--space-16);
}

.cart-products-block {
  padding-top: var(--cart-products-padding-top);
  padding-right: var(--cart-products-padding-right);
  padding-bottom: var(--cart-products-padding-bottom);
  padding-left: var(--cart-products-padding-left);
}

.cart-empty__message {
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin: 0;
}

.cart-empty__cta {
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: opacity var(--transition-base);
}

.cart-empty__cta:hover { opacity: 0.45; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blocks.cart_products.name",
  "settings": [
    {
      "type": "range",
      "id": "product_image_size",
      "label": "t:blocks.cart_products.settings.product_image_size.label",
      "min": 80,
      "max": 200,
      "step": 8,
      "unit": "px",
      "default": 96
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:blocks.cart_products.settings.aspect_ratio.label",
      "options": [
        { "value": "auto", "label": "t:blocks.cart_products.settings.aspect_ratio.options.auto" },
        { "value": "portrait", "label": "t:blocks.cart_products.settings.aspect_ratio.options.portrait" },
        { "value": "square", "label": "t:blocks.cart_products.settings.aspect_ratio.options.square" }
      ],
      "default": "auto"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "t:blocks.cart_products.settings.show_dividers.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:blocks.cart_products.settings.show_vendor.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:blocks.cart_products.settings.padding_header.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:blocks.cart_products.settings.padding_top.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:blocks.cart_products.settings.padding_bottom.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:blocks.cart_products.settings.padding_left.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:blocks.cart_products.settings.padding_right.label",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
