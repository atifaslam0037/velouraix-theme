{%- comment -%}
  Block: icon
  Path: blocks/icon.liquid
  Description: Standalone icon block. Renders uploaded image, custom SVG, or fallback.
               Used as a standalone @theme block in sections directly.
               Cannot be nested inside other @theme blocks (Shopify limitation).
{%- endcomment -%}

{% stylesheet %}
  /* ── icon block ── */
  .icon-block {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-shrink: 0;
    line-height: 0;
  }

  .icon-block__img {
    display: block;
    object-fit: contain;
  }

  .icon-block__svg-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-block__svg-wrap svg {
    display: block;
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}

{%- assign icon_size = block.settings.icon_size | default: 36 -%}
{%- assign icon_stroke = block.settings.icon_stroke_width | default: '1.5' -%}
{%- assign icon_color = block.settings.icon_color -%}

<div
  class="icon-block"
  aria-hidden="true"
  {{ block.shopify_attributes }}
  style="
    color: {{ icon_color }};
    width: {{ icon_size }}px;
    height: {{ icon_size }}px;
  "
>
  {%- if block.settings.icon_image != blank -%}
    {{
      block.settings.icon_image
      | image_url: width: 160
      | image_tag: class: 'icon-block__img', loading: 'lazy', width: '', height: '', alt: block.settings.icon_image.alt
      | default: '', style: 'width: '
      | append: icon_size
      | append: 'px; height: '
      | append: icon_size
      | append: 'px;'
    }}

  {%- elsif block.settings.custom_svg != blank -%}
    <span
      class="icon-block__svg-wrap"
      style="width: {{ icon_size }}px; height: {{ icon_size }}px;"
    >
      {{- block.settings.custom_svg -}}
    </span>

  {%- else -%}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="{{ icon_size }}"
      height="{{ icon_size }}"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="{{ icon_stroke }}"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      focusable="false"
    >
      <circle cx="12" cy="12" r="9"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Icon",
  "settings": [
    {
      "type": "header",
      "content": "t:general.icon_source",
      "info": "Image takes priority. If no image, custom SVG is used. If neither, a placeholder renders."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "t:general.icon_image",
      "info": "Upload an SVG or PNG icon."
    },
    {
      "type": "html",
      "id": "custom_svg",
      "label": "t:general.custom_svg",
      "info": "Paste raw <svg>…</svg> markup. Used only when no image is uploaded."
    },
    {
      "type": "header",
      "content": "t:general.style"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "t:general.icon_color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "t:general.icon_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "icon_stroke_width",
      "label": "t:general.stroke_width",
      "info": "Applies to custom SVG code only.",
      "options": [
        { "value": "1", "label": "t:general.thin" },
        { "value": "1.5", "label": "t:general.regular_border" },
        { "value": "2", "label": "t:general.bold_border" }
      ],
      "default": "1.5"
    }
  ],
  "presets": [{ "name": "Icon" }]
}
{% endschema %}
