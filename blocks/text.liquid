{%- comment -%}
  Block: text
  Path: blocks/text.liquid
  Description: Standalone rich text block with full typography,
               layout, color, appearance and padding controls.
{%- endcomment -%}

{% stylesheet %}
  /* ── text block ── */
  .block-text {
    display: block;
  }

  /* ── Width ── */
  .block-text--width-fit {
    width: fit-content;
  }
  .block-text--width-fill {
    width: 100%;
  }

  /* ── Max width ── */
  .block-text--maxwidth-narrow .block-text__content {
    max-width: 400px;
  }
  .block-text--maxwidth-normal .block-text__content {
    max-width: 640px;
  }
  .block-text--maxwidth-none .block-text__content {
    max-width: none;
  }

  /* ── Alignment ── */
  .block-text--left {
    text-align: left;
  }
  .block-text--center {
    text-align: center;
  }
  .block-text--right {
    text-align: right;
  }

  /* ── Typography presets ── */
  .block-text--preset-paragraph .block-text__content {
    font-size: var(--font-size-md, 1rem);
    font-weight: 400;
    line-height: 1.6;
  }

  .block-text--preset-h1 .block-text__content {
    font-size: var(--font-h1-size, 2.5rem);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.15;
    font-family: var(--font-heading);
  }

  .block-text--preset-h2 .block-text__content {
    font-size: var(--font-h2-size, 2rem);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.2;
    font-family: var(--font-heading);
  }

  .block-text--preset-h3 .block-text__content {
    font-size: var(--font-h3-size, 1.5rem);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.25;
    font-family: var(--font-heading);
  }

  .block-text--preset-h4 .block-text__content {
    font-size: var(--font-h4-size, 1.25rem);
    font-weight: var(--font-heading-weight, 600);
    line-height: 1.3;
    font-family: var(--font-heading);
  }

  .block-text--preset-h5 .block-text__content {
    font-size: var(--font-h5-size, 1.125rem);
    font-weight: var(--font-heading-weight, 600);
    line-height: 1.35;
    font-family: var(--font-heading);
  }

  .block-text--preset-h6 .block-text__content {
    font-size: var(--font-h6-size, 1rem);
    font-weight: var(--font-heading-weight, 600);
    line-height: 1.4;
    font-family: var(--font-heading);
  }

  /* ── RTE base styles ── */
  .block-text__content p {
    margin: 0 0 var(--space-3, 0.75rem);
  }
  .block-text__content p:last-child {
    margin-bottom: 0;
  }

  .block-text__content strong,
  .block-text__content b {
    font-weight: var(--font-heading-weight, 700);
  }

  .block-text__content a {
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: opacity 180ms ease;
  }

  .block-text__content a:hover {
    opacity: 0.75;
  }

  .block-text__content ul,
  .block-text__content ol {
    padding-left: var(--space-6, 1.5rem);
    margin: 0 0 var(--space-3, 0.75rem);
  }

  .block-text__content li {
    margin-bottom: var(--space-1, 0.25rem);
  }
{% endstylesheet %}

{%- liquid
  assign preset = block.settings.typography_preset
  assign width = block.settings.width
  assign max_width = block.settings.max_width
  assign alignment = block.settings.alignment
  assign text_color = block.settings.text_color
  assign bg_color = block.settings.background_color

  assign custom_font_size = block.settings.custom_font_size
  assign custom_font_weight = block.settings.custom_font_weight
  assign custom_line_height = block.settings.custom_line_height

  assign has_custom_style = false
  if preset == 'custom'
    assign has_custom_style = true
  endif
-%}

<div
  class="
    block-text
    block-text--width-{{ width }}
    block-text--maxwidth-{{ max_width }}
    block-text--{{ alignment }}
    block-text--preset-{{ preset }}
  "
  style="
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    {% if bg_color != 'rgba(0,0,0,0)' and bg_color != blank %}
      background-color: {{ bg_color }};
    {% endif %}
  "
  {{ block.shopify_attributes }}
>
  {%- if block.settings.text != blank -%}
    <div
      class="block-text__content rte"
      style="
        {% if text_color != 'rgba(0,0,0,0)' and text_color != blank %}
          color: {{ text_color }};
        {% endif %}
        {% if has_custom_style %}
          font-size: {{ custom_font_size }}px;
          font-weight: {{ custom_font_weight }};
          line-height: {{ custom_line_height }};
        {% endif %}
      "
    >
      {{ block.settings.text }}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:blocks.text.name",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:general.text",
      "default": "<p>Made with care</p>"
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:general.width",
      "options": [
        { "value": "fit", "label": "t:general.fit" },
        { "value": "fill", "label": "t:general.fill" }
      ],
      "default": "fill"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "t:general.max_width",
      "options": [
        { "value": "narrow", "label": "t:general.narrow" },
        { "value": "normal", "label": "t:general.normal" },
        { "value": "none", "label": "t:general.none" }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:general.alignment",
      "options": [
        { "value": "left", "label": "t:general.left" },
        { "value": "center", "label": "t:general.center" },
        { "value": "right", "label": "t:general.right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:general.typography"
    },
    {
      "type": "select",
      "id": "typography_preset",
      "label": "t:general.preset",
      "options": [
        { "value": "default", "label": "t:general.default" },
        { "value": "paragraph", "label": "t:general.paragraph" },
        { "value": "h1", "label": "t:general.heading_1" },
        { "value": "h2", "label": "t:general.heading_2" },
        { "value": "h3", "label": "t:general.heading_3" },
        { "value": "h4", "label": "t:general.heading_4" },
        { "value": "h5", "label": "t:general.heading_5" },
        { "value": "h6", "label": "t:general.heading_6" },
        { "value": "custom", "label": "t:general.custom" }
      ],
      "default": "h3"
    },
    {
      "type": "range",
      "id": "custom_font_size",
      "label": "t:general.custom_font_size",
      "info": "Only applies when preset is set to Custom.",
      "min": 10,
      "max": 80,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "custom_font_weight",
      "label": "t:general.custom_font_weight",
      "info": "Only applies when preset is set to Custom.",
      "options": [
        { "value": "300", "label": "t:general.light_weight" },
        { "value": "400", "label": "t:general.regular_weight" },
        { "value": "500", "label": "t:general.medium_weight" },
        { "value": "600", "label": "t:general.semibold_weight" },
        { "value": "700", "label": "t:general.bold_weight" },
        { "value": "800", "label": "t:general.extrabold_weight" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "custom_line_height",
      "label": "t:general.custom_line_height",
      "info": "Only applies when preset is set to Custom.",
      "options": [
        { "value": "1", "label": "t:general.line_height_1" },
        { "value": "1.2", "label": "t:general.line_height_1_2" },
        { "value": "1.4", "label": "t:general.line_height_1_4" },
        { "value": "1.6", "label": "t:general.line_height_1_6" },
        { "value": "1.8", "label": "t:general.line_height_1_8" },
        { "value": "2", "label": "t:general.line_height_2" }
      ],
      "default": "1.6"
    },
    {
      "type": "header",
      "content": "t:general.colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:general.text"
    },
    {
      "type": "header",
      "content": "t:general.appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:general.background"
    },
    {
      "type": "header",
      "content": "t:general.padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:general.top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:general.bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "t:general.left",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "t:general.right",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "t:blocks.text.presets.name" }]
}
{% endschema %}
