{%- comment -%}
  Block: _cart-summary.liquid
  Path: blocks/_cart-summary.liquid
  Description: Private theme block. Renders the order summary panel on the cart page.
    Contains subtotal (formatted with currency), tax note, and checkout CTA.
    The #cart-page-subtotal span is read by CartItemsComponent._syncGlobalUI()
    to keep the subtotal value in sync after AJAX mutations.
    Statically rendered by sections/main-cart.liquid via content_for 'block'.

  @example
  {%- content_for 'block', id: 'cart-page-summary', type: '_cart-summary' -%}
{%- endcomment -%}

{%- unless cart.empty? -%}
  <div
    class="cart-summary cart-summary--border-{{ block.settings.border_style }}{% unless block.settings.enable_sticky %} cart-summary--static{% endunless %}"
    id="cart-page-summary-panel"
    style="
      --cart-summary-padding-top: {{ block.settings.padding_top }}px;
      --cart-summary-padding-bottom: {{ block.settings.padding_bottom }}px;
      --cart-summary-padding-left: {{ block.settings.padding_left }}px;
      --cart-summary-padding-right: {{ block.settings.padding_right }}px;
      --cart-summary-border-thickness: {{ block.settings.border_thickness }}px;
      --cart-summary-border-opacity: {{ block.settings.border_opacity | divided_by: 100.0 }};
      --cart-summary-radius: {{ block.settings.corner_radius }}px;
    "
  >

    <div class="cart-summary__row">
      <span class="cart-summary__label">{{- 'cart.subtotal' | t | upcase -}}</span>
      <span class="cart-summary__value" id="cart-page-subtotal">
        {{- cart.total_price | money_with_currency -}}
      </span>
    </div>

    {%- if block.settings.show_tax_note -%}
      <p class="cart-summary__tax-note">
        {{- 'cart.taxes_and_shipping_policy_at_checkout_html' | t -}}
      </p>
    {%- endif -%}

    <div class="cart-summary__actions">
      <a
        href="{{ routes.checkout_url }}"
        class="cart-summary__checkout"
        id="cart-checkout-button"
        aria-label="{{ 'cart.checkout' | t }}"
      >
        {{- 'cart.checkout' | t | upcase -}}
      </a>

      <a href="{{ routes.cart_url }}" class="cart-summary__view-cart">
        {{- 'cart.view_cart' | t -}}
      </a>
    </div>

  </div>
{%- endunless -%}

{% stylesheet %}
/* ── Cart page summary block ── */
.cart-summary {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding-top: var(--cart-summary-padding-top);
  padding-right: var(--cart-summary-padding-right);
  padding-bottom: var(--cart-summary-padding-bottom);
  padding-left: var(--cart-summary-padding-left);
  background: oklch(from var(--color-text) l c h / 0.04);
  position: sticky;
  top: calc(var(--header-offset, var(--space-14)) + var(--space-6));
  border-radius: var(--cart-summary-radius);
}

.cart-summary--static { position: relative; top: auto; }
.cart-summary--border-solid {
  border: var(--cart-summary-border-thickness) solid oklch(from var(--color-text) l c h / var(--cart-summary-border-opacity));
}
.cart-summary--border-none { border: 0; }

.cart-summary__row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-4);
}

.cart-summary__label {
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.cart-summary__value {
  font-family: var(--font-primary);
  font-size: var(--font-size-sm);
  font-weight: 400;
  letter-spacing: 0.02em;
  color: var(--color-text);
}

.cart-summary__tax-note {
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  letter-spacing: 0.04em;
  margin: 0;
  opacity: 0.7;
}

.cart-summary__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

/* ── Checkout button ── */
.cart-summary__checkout {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: var(--space-4) var(--space-6);
  background: var(--color-text);
  color: var(--color-background);
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  min-height: 52px;
  border-radius: var(--button-radius);
  transition: opacity var(--transition-base);
}

.cart-summary__checkout:hover { opacity: 0.7; }

.cart-summary__checkout:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 3px;
}

/* ── View cart link ── */
.cart-summary__view-cart {
  display: block;
  text-align: center;
  font-family: var(--font-primary);
  font-size: var(--font-size-xs);
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: color var(--transition-base);
  padding-block: var(--space-1);
}

.cart-summary__view-cart:hover { color: var(--color-text); }
{% endstylesheet %}

{% schema %}
{
  "name": "Summary",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky summary",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tax_note",
      "label": "Show tax note",
      "default": true
    },
    {
      "type": "header",
      "content": "Borders"
    },
    {
      "type": "select",
      "id": "border_style",
      "label": "Style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "solid", "label": "Solid" }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_opacity",
      "label": "Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Left",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Right",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ]
}
{% endschema %}
