  {
    "name": "t:general.branding",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.logo"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:labels.logo_image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 40,
        "max": 300,
        "step": 4,
        "unit": "px",
        "label": "t:labels.logo_width",
        "default": 120
      },
      {
        "type": "text",
        "id": "logo_alt",
        "label": "t:labels.logo_alt",
        "placeholder": "t:placeholders.logo_alt"
      },
      {
        "type": "header",
        "content": "t:labels.favicon"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon_image"
      }
    ]
