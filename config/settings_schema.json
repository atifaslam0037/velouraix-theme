[
  {
    "name": "theme_info",
    "theme_name": "Velouraix",
    "theme_version": "1.0.0",
    "theme_author": "Velouraix",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },

  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "80rem", "label": "t:options.page_width.narrow" },
          { "value": "90rem", "label": "t:options.page_width.normal" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },

  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "header",
        "content": "t:labels.body_text"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "t:labels.font_size",
        "default": 16
      },
      {
        "type": "select",
        "id": "font_body_weight",
        "label": "t:labels.font_weight",
        "options": [
          { "value": "300", "label": "t:options.font_weight.light" },
          { "value": "400", "label": "t:options.font_weight.regular" },
          { "value": "500", "label": "t:options.font_weight.medium" },
          { "value": "600", "label": "t:options.font_weight.semibold" },
          { "value": "700", "label": "t:options.font_weight.bold" },
          { "value": "800", "label": "t:options.font_weight.extrabold" },
          { "value": "900", "label": "t:options.font_weight.black" }
        ],
        "default": "400"
      },
      {
        "type": "select",
        "id": "font_body_line_height",
        "label": "t:labels.line_height",
        "options": [
          { "value": "1.4", "label": "t:options.line_height.tight" },
          { "value": "1.6", "label": "t:options.line_height.normal" },
          { "value": "1.8", "label": "t:options.line_height.relaxed" }
        ],
        "default": "1.6"
      },
      {
        "type": "header",
        "content": "t:labels.headings"
      },
      {
        "type": "select",
        "id": "font_heading_weight",
        "label": "t:labels.font_weight",
        "options": [
          { "value": "300", "label": "t:options.font_weight.light" },
          { "value": "400", "label": "t:options.font_weight.regular" },
          { "value": "500", "label": "t:options.font_weight.medium" },
          { "value": "600", "label": "t:options.font_weight.semibold" },
          { "value": "700", "label": "t:options.font_weight.bold" },
          { "value": "800", "label": "t:options.font_weight.extrabold" },
          { "value": "900", "label": "t:options.font_weight.black" }
        ],
        "default": "700"
      },
      {
        "type": "select",
        "id": "font_heading_line_height",
        "label": "t:labels.line_height",
        "options": [
          { "value": "1.1", "label": "t:options.line_height.tight" },
          { "value": "1.25", "label": "t:options.line_height.normal" },
          { "value": "1.4", "label": "t:options.line_height.relaxed" }
        ],
        "default": "1.25"
      },
      {
        "type": "range",
        "id": "font_h1_size",
        "min": 24,
        "max": 96,
        "step": 2,
        "unit": "px",
        "label": "t:labels.h1_size",
        "default": 48
      },
      {
        "type": "range",
        "id": "font_h2_size",
        "min": 20,
        "max": 72,
        "step": 2,
        "unit": "px",
        "label": "t:labels.h2_size",
        "default": 36
      },
      {
        "type": "range",
        "id": "font_h3_size",
        "min": 16,
        "max": 56,
        "step": 2,
        "unit": "px",
        "label": "t:labels.h3_size",
        "default": 28
      },
      {
        "type": "range",
        "id": "font_h4_size",
        "min": 14,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "t:labels.h4_size",
        "default": 22
      },
      {
        "type": "range",
        "id": "font_h5_size",
        "min": 12,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "t:labels.h5_size",
        "default": 18
      },
      {
        "type": "range",
        "id": "font_h6_size",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "t:labels.h6_size",
        "default": 14
      }
    ]
  },

