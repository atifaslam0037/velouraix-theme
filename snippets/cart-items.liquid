{%- comment -%}
  Snippet: cart-items.liquid
  Path: snippets/cart-items.liquid
  Description: Renders cart line items for drawer and cart page.
    Drawer: stacked compact layout.
    Page (desktop): table layout with qty column and total column aligned under headers.

  @param {string}  [context]       - 'drawer' or 'page'.
  @param {boolean} [show_vendor]   - Show product vendor.
  @param {boolean} [show_dividers] - Show item divider lines.
  @param {number}  [image_size]    - Image size in px.
  @param {string}  [aspect_ratio]  - 'auto' | 'portrait' | 'square'.

  @example
  {% render 'cart-items', context: 'drawer' %}
{%- endcomment -%}

{%- liquid
  assign is_drawer   = false
  if context == 'drawer'
    assign is_drawer = true
  endif
  assign img_size    = image_size | default: 96
  assign no_dividers = false
  unless show_dividers
    assign no_dividers = true
  endunless
-%}

<cart-items-component
  class="cart-items{% if is_drawer %} cart-items--drawer{% endif %}{% if no_dividers %} cart-items--no-dividers{% endif %}{% if aspect_ratio == 'square' %} cart-items--ratio-square{% elsif aspect_ratio == 'portrait' %} cart-items--ratio-portrait{% endif %}"
  style="--cart-item-image-size: {{ img_size }}px;"
  data-cart-line-items
  {% if is_drawer %}data-drawer{% endif %}
  data-section-id="main-cart"
>
  {%- if cart.item_count > 0 -%}
    <ul class="cart-items__list" role="list" aria-label="{{ 'cart.title' | t }}">
      {%- for item in cart.items -%}
        <li
          class="cart-item"
          data-cart-item="{{ item.key }}"
          data-variant-id="{{ item.variant_id }}"
          data-line="{{ forloop.index }}"
          id="cart-item-{{ item.key }}"
        >

          {%- comment -%} IMAGE {%- endcomment -%}
          <a href="{{ item.url }}" class="cart-item__image-wrap" tabindex="-1" aria-hidden="true">
            {%- if item.image != blank -%}
              <img
                class="cart-item__image"
                src="{{ item.image | image_url: width: 300 }}"
                srcset="
                  {{ item.image | image_url: width: 150 }} 150w,
                  {{ item.image | image_url: width: 300 }} 300w,
                  {{ item.image | image_url: width: 600 }} 600w
                "
                sizes="(min-width: 990px) 120px, 96px"
                alt="{{ item.image.alt | escape | default: item.title | escape }}"
                width="150"
                height="{{ 150 | divided_by: item.image.aspect_ratio | round }}"
                loading="lazy"
                decoding="async"
              >
            {%- else -%}
              <span class="cart-item__image-placeholder" aria-hidden="true">
                {{- 'product-1' | placeholder_svg_tag: 'cart-item__placeholder-svg' -}}
              </span>
            {%- endif -%}
          </a>

          {%- comment -%} BODY: meta + price + controls (controls only used in drawer / mobile) {%- endcomment -%}
          <div class="cart-item__body">
            <div class="cart-item__meta">
              <a href="{{ item.url }}" class="cart-item__name">{{- item.product.title | escape -}}</a>

              {%- if show_vendor -%}
                <p class="cart-item__vendor">{{- item.product.vendor | escape -}}</p>
              {%- endif -%}

              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__variant">{{- item.variant.title | escape -}}</p>
              {%- endunless -%}

              {%- if item.properties.size > 0 -%}
                {%- for prop in item.properties -%}
                  {%- assign first_char = prop.first | slice: 0 -%}
                  {%- if prop.last != blank and first_char != '_' -%}
                    <p class="cart-item__property">
                      <span class="cart-item__property-key">{{ prop.first | escape }}:</span>
                      <span class="cart-item__property-val">
                        {%- if prop.last contains '/uploads/' -%}
                          <a href="{{ prop.last }}" target="_blank" rel="noopener noreferrer">{{ prop.last | split: '/' | last }}</a>
                        {%- else -%}
                          {{- prop.last | escape -}}
                        {%- endif -%}
                      </span>
                    </p>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>

            {%- comment -%} Price row — always rendered, CSS hides line-total on desktop page {%- endcomment -%}
            <div class="cart-item__price-row">
              <div class="cart-item__unit-price">
                {%- if item.original_price > item.price -%}
                  <s class="cart-item__original-price">{{- item.original_price | money -}}</s>
                {%- endif -%}
                <span class="cart-item__price{% if item.original_price > item.price %} cart-item__price--sale{% endif %}">
                  {{- item.price | money -}}
                </span>
              </div>
              {%- comment -%} Line total shown inline on mobile/drawer; hidden on desktop (uses separate col) {%- endcomment -%}
              <span class="cart-item__line-total" id="cart-item-total-{{ item.key }}">
                {{- item.final_line_price | money -}}
              </span>
            </div>

            {%- comment -%} Controls inside body — shown on mobile + drawer. On desktop the qty-col below handles the grid column. {%- endcomment -%}
            <div class="cart-item__controls">
              {%- render 'quantity-input',
                id: item.key,
                name: 'updates[]',
                value: item.quantity,
                min: 0,
                index: forloop.index
              -%}
              <button
                class="cart-item__remove"
                type="button"
                data-cart-remove="{{ item.key }}"
              >
                <span class="visually-hidden">{{ 'cart.remove' | t }}: {{ item.title | escape }}</span>
                <span class="cart-item__remove-icon" aria-hidden="true">{%- render 'icon', name: 'trash' -%}</span>
                <span class="cart-item__remove-text" aria-hidden="true">{{- 'cart.remove' | t -}}</span>
              </button>
            </div>

            <p class="cart-item__error" id="Line-item-error-{{ item.key }}" role="alert" aria-live="assertive"></p>
          </div>

          {%- unless is_drawer -%}
            <div class="cart-item__qty-col">
              {%- assign desktop_id = item.key | append: '-desktop' -%}
              {%- render 'quantity-input',
                  id: desktop_id,
                  name: 'qty-display',
                  value: item.quantity,
                  min: 0,
                  index: forloop.index
              -%}
            </div>
            <span class="cart-item__total-col" id="cart-item-total-desktop-{{ item.key }}">
              {{- item.final_line_price | money -}}
            </span>
            <button
              class="cart-item__remove cart-item__remove--desktop"
              type="button"
              data-cart-remove="{{ item.key }}"
            >
              <span class="visually-hidden">{{ 'cart.remove' | t }}: {{ item.title | escape }}</span>
              <span class="cart-item__remove-icon" aria-hidden="true">{%- render 'icon', name: 'trash' -%}</span>
              <span class="cart-item__remove-text" aria-hidden="true">{{- 'cart.remove' | t -}}</span>
            </button>
          {%- endunless -%}

        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</cart-items-component>
