{%- liquid
  assign target = product.selected_or_first_available_variant
-%}

<div class="product-price-snippet">
  <div class="product-price-snippet__row">
    <span class="product-price-snippet__current">
      {{- target.price | money_with_currency -}}
    </span>

    {%- if show_compare_at and target.compare_at_price > target.price -%}
      <s class="product-price-snippet__compare">
        {{- target.compare_at_price | money_with_currency -}}
      </s>
    {%- endif -%}
  </div>

  {%- if show_installments and product.selling_plan_groups.size == 0 and target.available -%}
    <div class="product-price-snippet__installments">
      {{ form | payment_terms }}
    </div>
  {%- endif -%}

  {%- if show_tax_notice -%}
    <p class="product-price-snippet__tax">
      {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
        {{ 'products.product.include_taxes_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
      {%- elsif cart.taxes_included -%}
        {{ 'products.product.include_taxes' | t }}
      {%- elsif shop.shipping_policy.body != blank -%}
        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
      {%- else -%}
        {{ 'products.product.taxes_at_checkout' | t }}
      {%- endif -%}
    </p>
  {%- endif -%}
</div>
