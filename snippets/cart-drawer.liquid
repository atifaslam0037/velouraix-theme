<cart-drawer
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cart-drawer-title"
  aria-hidden="true"
>
  <span
    id="cart-live-region"
    class="visually-hidden"
    aria-live="polite"
    aria-atomic="true"
  ></span>
  <div class="cart-drawer__overlay" data-cart-close></div>

  <div class="cart-drawer__panel">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title" id="cart-drawer-title">
        {{ 'sections.header.summary_items' | t }} <span class="cart-drawer__count" id="cart-drawer-count">( {{ cart.item_count }} )</span>
      </h2>
      <button
        class="cart-drawer__close"
        type="button"
        data-cart-close
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {%- render 'icon', name: 'close' -%}
      </button>
    </div>

    <div class="cart-drawer__body" id="cart-drawer-items">
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          <div class="cart-item" data-cart-item="{{ item.key }}">
            <a href="{{ item.url }}" class="cart-item__image-link">
              {%- if item.image != blank -%}
                <img
                  class="cart-item__image"
                  src="{{ item.image | image_url: width: 160 }}"
                  alt="{{ item.image.alt | default: item.title | escape }}"
                  width="80"
                  height="100"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
            <div class="cart-item__info">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              <div class="cart-item__price-row">
                <span class="cart-item__price">{{ item.final_line_price | money }}</span>
                <div class="cart-item__qty">
                  <button
                    class="cart-item__qty-btn"
                    type="button"
                    data-cart-qty-change="{{ item.key }}"
                    data-change="-1"
                    aria-label="{{ 'cart.decrease_quantity' | t }}"
                  >
                    {%- render 'icon', name: 'minus' -%}
                  </button>
                  <span class="cart-item__qty-value">{{ item.quantity }}</span>
                  <button
                    class="cart-item__qty-btn"
                    type="button"
                    data-cart-qty-change="{{ item.key }}"
                    data-change="1"
                    aria-label="{{ 'cart.increase_quantity' | t }}"
                  >
                    {%- render 'icon', name: 'plus' -%}
                  </button>
                </div>
                <button
                  class="cart-item__remove"
                  type="button"
                  data-cart-remove="{{ item.key }}"
                  aria-label="{{ 'cart.remove' | t }}: {{ item.title }}"
                >
                  {{ 'cart.remove' | t }}
                </button>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="cart-drawer__empty">
          <p>{{ 'cart.empty' | t }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary" data-cart-close>
            {{ 'cart.continue_shopping' | t }}
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <div class="cart-drawer__subtotal">
          <span>{{ 'cart.subtotal' | t }}</span>
          <span id="cart-drawer-subtotal">{{ cart.total_price | money }}</span>
        </div>
        <a href="{{ routes.checkout_url }}" class="btn btn--primary btn--full btn--pill">
          {{ 'cart.checkout' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</cart-drawer>

{% stylesheet %}
  /* Uses visibility + pointer-events for animation support */
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 300;
    visibility: hidden;
    pointer-events: none;
  }
  .cart-drawer[open] {
    visibility: visible;
    pointer-events: auto;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-text) 0%, transparent);
    transition: background 0.3s ease;
  }
  .cart-drawer[open] .cart-drawer__overlay {
    background: color-mix(in srgb, var(--color-text) 40%, transparent);
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(calc(var(--space-16) * 6 + var(--space-4)), 100vw);
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cart-drawer[open] .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-6);
    border-bottom: var(--space-1) solid var(--color-border);
    flex-shrink: 0;
  }

  .cart-drawer__title {
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
    color: var(--color-text);
  }

  .cart-drawer__count {
    color: var(--color-text-muted);
    margin-left: var(--space-1);
  }

  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }
  .cart-drawer__close:hover {
    opacity: 0.5;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--space-6);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-4);
    padding-block: 20px;
    border-bottom: var(--space-1) solid var(--color-border);
  }

  .cart-item__image-link {
    display: block;
    flex-shrink: 0;
  }
  .cart-item__image {
    width: calc(var(--space-16) + var(--space-4));
    height: calc(var(--space-16) + var(--space-8) + var(--space-1));
    object-fit: cover;
    display: block;
  }

  .cart-item__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cart-item__title {
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .cart-item__title:hover {
    opacity: 0.5;
  }

  .cart-item__variant {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cart-item__price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    margin-top: auto;
  }

  .cart-item__price {
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    font-weight: 400;
    color: var(--color-text);
  }

  .cart-item__qty {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    border: var(--space-1) solid var(--color-border);
    padding: var(--space-1) var(--space-2);
  }

  .cart-item__qty-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: 0;
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }
  .cart-item__qty-btn:hover {
    opacity: 0.5;
  }

  .cart-item__qty-value {
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    min-width: var(--space-4);
    text-align: center;
  }

  .cart-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0;
    transition: color 0.2s ease;
  }
  .cart-item__remove:hover {
    color: var(--color-text);
  }

  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    padding: calc(var(--space-16) - var(--space-1)) var(--space-6);
    text-align: center;
  }
  .cart-drawer__empty p {
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cart-drawer__footer {
    padding: var(--space-5) var(--space-6);
    border-top: var(--space-1) solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-1);
  }

  .btn {
    display: block;
    text-align: center;
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    border: var(--space-1) solid transparent;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .btn--full {
    width: 100%;
  }
  .btn--primary {
    background: var(--color-btn-primary-bg);
    color: var(--color-btn-primary-text);
    border-color: var(--color-btn-primary-bg);
    border-radius: var(--style-border-radius-buttons, 0);
  }
  .btn--primary:hover {
    background: var(--color-btn-primary-bg-hover);
    border-color: var(--color-btn-primary-bg-hover);
  }
  .btn--secondary {
    background: var(--color-btn-secondary-bg, transparent);
    color: var(--color-btn-secondary-text);
    border-color: var(--color-border);
    border-radius: var(--style-border-radius-buttons, 0);
  }
  .btn--secondary:hover {
    background: var(--color-btn-secondary-bg-hover);
    color: var(--color-btn-secondary-text-hover);
  }
  .btn--pill {
    border-radius: var(--radius-full);
  }
{% endstylesheet %}
