{% doc %}
  Global wrapper for Quick Add Modal.
  Only rendered once at the bottom of layout/theme.liquid.
  All open/close/fetch/slider logic is handled by component-quick-add.js.
{% enddoc %}

<link rel="stylesheet" href="{{ 'component-quick-add.css' | asset_url }}">

<dialog
  id="QuickAddModal"
  class="quick-add-modal"
  aria-modal="true"
  aria-labelledby="QuickAddTitle"
>
  <div class="quick-add-modal__overlay" data-quick-add-close></div>

  <div class="quick-add-modal__content-wrapper" role="document">
    <button
      type="button"
      class="quick-add-modal__close"
      aria-label="Close"
      data-quick-add-close
    >
      {%- render 'icon', name: 'close', aria_hidden: true -%}
    </button>

    <div class="quick-add-modal__content" data-quick-add-content>
      {{- '' -}}
    </div>
  </div>
</dialog>