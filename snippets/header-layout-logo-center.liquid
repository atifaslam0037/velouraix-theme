{%- liquid
  assign cart_qty_sum = 0
  for item in cart.items
    assign cart_qty_sum = cart_qty_sum | plus: item.quantity
  endfor
-%}
{% doc %}
  Layout: [NAV LEFT] — [LOGO CENTER] — [ICONS RIGHT]
  Desktop: text nav left, logo center, text-style action icons right.
  Mobile: MENU text left, logo center, CART text+count right.

  @param {block} logo_block - Logo block
  @param {block} nav_left_block - Navigation block
  @param {block} nav_right_block - Icons/actions block
  @param section_blocks - All section blocks (for mega menu)
  @param {string} search_style - 'modal' or 'page'
  @param {string} cart_style - 'drawer' or 'page'

  @example
  {% render 'header-layout-logo-center', logo_block: logo_block, nav_left_block: nav_left_block, nav_right_block: nav_right_block, section_blocks: section_blocks, search_style: 'modal', cart_style: 'drawer' %}
{% enddoc %}

<div class="header-layout header-layout--logo-center">
  {%- comment -%} ── START: MENU button (mobile) + desktop nav ── {%- endcomment -%}
  <div class="header-layout__start">
    {%- comment -%} Mobile: MENU text button {%- endcomment -%}
    <button
      class="header__mobile-toggle"
      type="button"
      aria-label="{{ 'sections.header.mobile_menu_label' | t }}"
      aria-expanded="false"
      aria-controls="mobile-menu-drawer"
      data-mobile-menu-toggle
    >
      <span class="visually-hidden">{{ 'sections.header.menu_label' | t }}</span>
      {%- render 'icon', name: 'hamburger' -%}
    </button>

    {%- comment -%} Desktop: nav links {%- endcomment -%}
    {%- if nav_left_block != null -%}
      <nav class="header__nav header__nav--desktop" aria-label="{{ 'sections.header.nav_aria_label' | t }}">
        {%- render 'header-nav', block: nav_left_block, nav_style: 'mega_menu', section_blocks: section_blocks -%}
      </nav>
    {%- endif -%}
  </div>

  {%- comment -%} ── CENTER: logo ── {%- endcomment -%}
  <div class="header-layout__center">
    {%- if logo_block != null -%}
      {%- render 'header-logo', block: logo_block -%}
    {%- endif -%}
  </div>

  {%- comment -%} ── END: cart (mobile) / full actions (desktop) ── {%- endcomment -%}
  <div class="header-layout__end">
    {%- comment -%}
      MOBILE: show only CART text + count badge.
      Respects cart_style: drawer triggers the drawer, page goes to cart page.
    {%- endcomment -%}
    <div class="header-end--mobile">
      {%- if nav_right_block != null and nav_right_block.settings.show_cart -%}
        {%- if cart_style == 'drawer' -%}
          <button
            class="header-action-text"
            type="button"
            aria-label="{{ 'sections.header.cart_aria_label' | t: count: cart_qty_sum }}"
            data-cart-toggle
          >
            <span class="visually-hidden">{{ 'sections.header.cart_label' | t }}</span>
            {%- render 'icon', name: 'cart' -%}
            <span
              class="header-action-text__badge{% if cart_qty_sum == 0 %} hidden{% endif %}"
              id="cart-count-mobile"
              aria-live="polite"
              aria-atomic="true"
            >
              {{- cart_qty_sum -}}
            </span>
          </button>
        {%- else -%}
          <a
            href="{{ routes.cart_url }}"
            class="header-action-text"
            aria-label="{{ 'sections.header.cart_aria_label' | t: count: cart_qty_sum }}"
          >
            <span class="visually-hidden">{{ 'sections.header.cart_label' | t }}</span>
            {%- render 'icon', name: 'cart' -%}
            <span
              class="header-action-text__badge{% if cart_qty_sum == 0 %} hidden{% endif %}"
              id="cart-count-mobile"
              aria-live="polite"
              aria-atomic="true"
            >
              {{- cart_qty_sum -}}
            </span>
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%}
      DESKTOP: full icon/text action set — search, account, wishlist, cart.
      Respects all show_* settings and cart_style / search_style globals.
    {%- endcomment -%}
    <div class="header-end--desktop">
      {%- if nav_right_block != null -%}
        {%- render 'header-icons', block: nav_right_block, search_style: search_style, cart_style: cart_style -%}
      {%- endif -%}
    </div>
  </div>
</div>
