{%- comment -%}
  Snippet: pagination
  Path: snippets/pagination.liquid
  Description: Accessible pagination links with current page state.
  Parameters:
    - paginate {paginate} required
  Example:
    {% render 'pagination', paginate: paginate %}
{%- endcomment -%}

{%- if paginate.pages > 1 -%}
  <nav class="pagination" aria-label="{{ 'general.pagination.label' | t }}">
    <ul class="pagination__list" role="list">
      {%- if paginate.previous -%}
        <li class="pagination__item">
          <a class="pagination__link" href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
            {{- 'general.pagination.previous' | t -}}
          </a>
        </li>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        <li class="pagination__item">
          {%- if part.is_link -%}
            <a class="pagination__link" href="{{ part.url }}">{{ part.title | escape }}</a>
          {%- else -%}
            <span class="pagination__link{% if part.title == paginate.current_page %} is-current{% endif %}"{% if part.title == paginate.current_page %} aria-current="page"{% endif %}>
              {{- part.title -}}
            </span>
          {%- endif -%}
        </li>
      {%- endfor -%}

      {%- if paginate.next -%}
        <li class="pagination__item">
          <a class="pagination__link" href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
            {{- 'general.pagination.next' | t -}}
          </a>
        </li>
      {%- endif -%}
    </ul>
  </nav>
{%- endif -%}
